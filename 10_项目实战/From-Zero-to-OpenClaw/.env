# penclaw onfiguration
# copy this file to .env and fill in your actual values

# Feishu(Lark)Bot configuration
FEISHU_APP_ID=your feishu app id here
FEISHU_APP_SECRET=your feishu app secret here

# Doubao(ByteDance)API Configuration
DOUBAO_API_KEY=your doubao api key here

# Optional: change the default token for gateway access
GATEWAY_TOKEN=your custom token here